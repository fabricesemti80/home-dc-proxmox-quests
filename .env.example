# Copy to .env and fill from Doppler or an existing local secrets source.

# Proxmox / Terraform
export TF_VAR_proxmox_endpoint="https://10.0.40.15:8006"
export TF_VAR_proxmox_insecure="true"
export TF_VAR_proxmox_username="root@pam"
export TF_VAR_proxmox_password="replace-me"
export TF_VAR_root_ssh_public_keys='["ssh-rsa replace-me"]'

# Ansible guest access
export ANSI_ROOT_PASSWORD="replace-me"

# Tailscale
export TAILSCALE_AUTHKEY="replace-me"
export TAILSCALE_OAUTH_CLIENT_ID="replace-me"
export TAILSCALE_OAUTH_CLIENT_SECRET="replace-me"
export TAILSCALE_TAILNET="koala-dominant.ts.net"
export TAILSCALE_TECHNITIUM_PRIMARY_DNS="10.0.40.53"
export TAILSCALE_TECHNITIUM_SECONDARY_DNS="10.0.40.54"
export TF_VAR_tailscale_oauth_client_id="${TAILSCALE_OAUTH_CLIENT_ID}"
export TF_VAR_tailscale_oauth_client_secret="${TAILSCALE_OAUTH_CLIENT_SECRET}"
export TF_VAR_tailscale_tailnet="${TAILSCALE_TAILNET}"
export TF_VAR_tailscale_technitium_primary_dns_server="${TAILSCALE_TECHNITIUM_PRIMARY_DNS}"
export TF_VAR_tailscale_technitium_secondary_dns_server="${TAILSCALE_TECHNITIUM_SECONDARY_DNS}"

# Core services
export TECHNITIUM_ADMIN_PASSWORD="replace-me"
export TECHNITIUM_NODE0_TOKEN="replace-me"
export TECHNITIUM_NODE1_TOKEN="replace-me"
export TECHNITIUM_NODE2_TOKEN="replace-me"
export PORTAINER_ADMIN_PASSWORD="replace-me"
export PORTAINER_BE_LICENSE=""  # leave empty for CE; set to enable BE

# Komodo
export KOMODO_DATABASE_PASSWORD="replace-me"
export KOMODO_INIT_ADMIN_PASSWORD="replace-me"
export KOMODO_WEBHOOK_SECRET="replace-me"
export KOMODO_JWT_SECRET="replace-me"
export KOMODO_API_KEY="replace-me"
export KOMODO_API_SECRET="replace-me"

# Apps
export VAULTWARDEN_APP_URL="https://vaultwarden.koala-dominant.ts.net"
export VAULTWARDEN_ADMIN_TOKEN="replace-me"
export BESZEL_APP_URL="https://beszel.koala-dominant.ts.net"
export BESZEL_AGENT_KEY="replace-me"
export ARCANE_APP_URL="https://arcane.koala-dominant.ts.net"
export ARCANE_ENCRYPTION_KEY="replace-me"
export ARCANE_JWT_SECRET="replace-me"
export KESTRA_HOSTNAME="kestra.koala-dominant.ts.net"
export KESTRA_BASIC_AUTH_USERNAME="fabrice.semti@gmail.com"
export KESTRA_BASIC_AUTH_PASSWORD="replace-me"
export KESTRA_POSTGRES_PASSWORD="replace-me"
export KESTRA_SSH_PRIVATE_KEY_PATH="/srv/docker/gitops/secrets/homelab_ssh_key"
export KESTRA_FLOW_GIT_URL="https://github.com/fabricesemti80/home-kestra.git"
export KESTRA_FLOW_GIT_BRANCH="main"
export KESTRA_FLOW_GIT_PATH="flows"
export KESTRA_FLOW_NAMESPACE="homelab.ops"
export HOMELAB_PVE_HOSTS="pve-0 pve-1 pve-2"
export HOMELAB_PVE_SHUTDOWN_ORDER="pve-2 pve-1 pve-0"
